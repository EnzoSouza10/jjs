[app]
title = AUTO JJS
package.name = autojjs
package.domain = org.enzo
source.dir = .
source.include_exts = py,kv,png,jpg,ico
version = 4.0.0
requirements = python3,kivy
orientation = portrait
fullscreen = 0
android.permissions = VIBRATE
android.api = 35
android.minapi = 24
android.archs = arm64-v8a, armeabi-v7a

[buildozer]
log_level = 2
warn_on_root = 1
